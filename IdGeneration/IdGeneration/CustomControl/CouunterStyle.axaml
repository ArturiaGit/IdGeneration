<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:customControl="clr-namespace:IdGeneration.CustomControl"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border
            Background="White"
            Height="720"
            Padding="20"
            Width="1289">
            <customControl:CounterStyle Watermark="年" />
        </Border>
    </Design.PreviewWith>

    <Style Selector="customControl|CounterStyle">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        ClipToBounds="True"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Height="{TemplateBinding Height}"
                        Width="{TemplateBinding Width}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox
                                BorderThickness="0"
                                FontFamily="{StaticResource CRG_Regular}"
                                FontSize="20"
                                Grid.Column="0"
                                HorizontalContentAlignment="Left"
                                Name="PART_InputBox"
                                Text="{TemplateBinding Text,
                                                       Mode=TwoWay}"
                                VerticalContentAlignment="Center"
                                Watermark="{TemplateBinding Watermark}" />
                            <StackPanel
                                Grid.Column="1"
                                IsVisible="false"
                                Margin="0,0,5,0"
                                Orientation="Vertical"
                                VerticalAlignment="Center">
                                <Button
                                    Background="Transparent"
                                    Command="{TemplateBinding}"
                                    Height="13"
                                    Name="PART_UpButton"
                                    Width="20">
                                    <Image
                                        Height="13"
                                        HorizontalAlignment="Center"
                                        Source="avares://IdGeneration/Assets/arrow_up.png"
                                        Width="13" />
                                </Button>
                                <Button
                                    Background="Transparent"
                                    Height="13"
                                    Name="PART_DownButton"
                                    Width="20">
                                    <Image
                                        Height="13"
                                        HorizontalAlignment="Center"
                                        Source="avares://IdGeneration/Assets/arrow_up.png"
                                        Width="13">
                                        <Image.RenderTransform>
                                            <RotateTransform Angle="180" />
                                        </Image.RenderTransform>
                                    </Image>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Style Selector="^:pointerover">
            <Style Selector="^ /template/ Border">
                <Setter Property="BorderBrush" Value="#ACACAC" />
            </Style>
            <Style Selector="^ /template/ StackPanel">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>

        <Style Selector="^:focus-within">
            <Style Selector="^ /template/ Border">
                <Setter Property="BorderBrush" Value="#BEBEBE" />
            </Style>
        </Style>
    </Style>

    <Style Selector="TextBox">
        <Style Selector="^ /template/ TextBlock#PART_Watermark">
            <Setter Property="FontFamily" Value="{StaticResource CRG_Regular}" />
            <Setter Property="Foreground" Value="#BEBEBE" />
            <Setter Property="FontSize" Value="20" />
        </Style>

        <Style Selector="^:focus /template/ Border#PART_BorderElement">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
    </Style>
</Styles>
